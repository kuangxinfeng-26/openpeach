OPENPEACH_HOME="$HOME/.openpeach"
# Optional override. Defaults to $OPENPEACH_HOME/families/$TAOQIBAO_FAMILY_ID/state.db.
TAOQIBAO_STATE_DB=""
TAOQIBAO_FAMILY_ID="main"
TAOQIBAO_CORE_AGENT_ID="main"
TAOQIBAO_OWNER_TELEGRAM_USER_IDS="123456789"
TELEGRAM_BOT_TOKEN="replace-me"
TAOQIBAO_TELEGRAM_API_ROOT=""
# Optional Telegram egress proxy for restricted networks.
# The Telegram adapter honors standard proxy env vars when apiRoot is empty.
# OpenPeach loads .env with override enabled, so these values win over
# inherited host proxy variables.
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""
NO_PROXY="localhost,127.0.0.1,::1"
# You can populate the model fields below from .openpeach/model.runtime.local.toml
# with: npm run model:sync
TAOQIBAO_MODEL_BASE_URL="https://api.example.com/v1"
TAOQIBAO_MODEL_API_KEY="replace-me"
TAOQIBAO_MODEL_NAME="replace-me"
TAOQIBAO_MODEL_TIMEOUT_MS="30000"
TAOQIBAO_LOG_LEVEL="info"
